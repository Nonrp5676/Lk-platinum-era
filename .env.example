# ─── Database (Turso / libSQL) ────────────────────────────────────────────────
# Create a free database at https://turso.tech
TURSO_CONNECTION_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ─── Supabase (Storage for files) ────────────────────────────────────────────
# Create a free project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── Email (SMTP for verification codes) ─────────────────────────────────────
MAIL_HOST=your-smtp-host.com
MAIL_PORT=465
MAIL_USER=your-email@your-domain.com
MAIL_PASS=your-smtp-password
MAIL_FROM=your-email@your-domain.com
MAIL_FROM_NAME=Your Label

# ─── App URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ─── Optional integrations ───────────────────────────────────────────────────
# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# AI Chat (optional — any of these)
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=

# Resend email (optional alternative to SMTP)
RESEND_API_KEY=
